{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": "../../..",
    "lib": ["ESNext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "paths": {
      "@github/*": [".github/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2019",
    "types": ["node"]
  },
  "include": ["../../../.github/**/*.ts"]
}
