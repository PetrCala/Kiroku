{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    // Inherit `module: preserve` from expo/tsconfig.base. Overriding it to
    // `commonjs` while the base keeps `moduleResolution: bundler` trips TS5095
    // (bundler resolution requires module preserve/es2015+), which aborts `tsc`.
    "types": ["react-native", "jest", "node"],
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "jsx": "react-native",
    "isolatedModules": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "incremental": true,
    "sourceMap": true,
    "paths": {
      "*": ["./*"],
      "@assets/*": ["./assets/*"],
      "@auth/*": ["./src/libs/auth/*"],
      "@components/*": ["./src/components/*"],
      "@context/*": ["./src/context/*"],
      "@database/*": ["./src/database/*"],
      "@desktop/*": ["./desktop/*"],
      "@firebase/auth": ["./node_modules/@firebase/auth/dist/index.rn.d.ts"],
      "@github/*": ["./.github/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@libs/*": ["./src/libs/*"],
      "@navigation/*": ["./src/libs/Navigation/*"],
      "@screens/*": ["./src/screens/*"],
      "@src/*": ["./src/*"],
      "@storage/*": ["./src/storage/*"],
      "@styles/*": ["./src/styles/*"],
      "@utils/*": ["./src/utils/*"],
      "@userActions/*": ["./src/libs/actions/*"]
    }
  },
  // ts-node-only overrides (ignored by tsc). The root config inherits
  // `module: preserve` + `moduleResolution: bundler` from expo/tsconfig.base so
  // `tsc` passes, but ts-node would then hand `.ts` entries to Node's native ESM
  // loader (ERR_UNKNOWN_FILE_EXTENSION on Node 20). Force CommonJS so ts-node's
  // require hook compiles `.ts` itself; `node` resolution avoids TS5095 (bundler
  // requires module preserve/es2015+); tsconfig-paths resolves `@src/*` aliases.
  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node"
    }
  },
  "include": [
    "__mocks__",
    "__tests__",
    "assets",
    "src",
    "config",
    ".github/**/*",
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "scripts",
    "app.json",
    "package.json", // Application version import
    "firebase.json",
    "react-native.config.js",
    "local/tests/integration"
  ],
  "exclude": [
    "**/node_modules/*",
    "**/dist/*",
    ".github/actions/**/index.js",
    "**/local/*"
  ]
}
